@echo off\nREM Barcode Management System - Automated Setup Script (Windows)\nREM This script will install and setup the entire application\n\nsetlocal enabledelayedexpansion\n\necho ===============================================================\necho 🚀 Barcode Management ^& Security Gate Entry System\necho    Automated Installation Script (Windows)\necho ===============================================================\necho.\n\nREM Check if Node.js is installed\necho [1/7] Checking Node.js installation...\nnode --version >nul 2>&1\nif errorlevel 1 (\n    echo ❌ Node.js is not installed. Please install from https://nodejs.org/\n    pause\n    exit /b 1\n)\nfor /f \"tokens=*\" %%i in ('node --version') do set NODE_VERSION=%%i\necho ✅ Node.js %NODE_VERSION% found\n\nREM Check if MySQL is installed\necho.\necho [2/7] Checking MySQL installation...\nmysql --version >nul 2>&1\nif errorlevel 1 (\n    echo ❌ MySQL is not installed. Please install from https://www.mysql.com/downloads/\n    pause\n    exit /b 1\n)\necho ✅ MySQL found\n\nREM Check if Git is installed\necho.\necho [3/7] Checking Git installation...\ngit --version >nul 2>&1\nif errorlevel 1 (\n    echo ❌ Git is not installed. Please install from https://git-scm.com/\n    pause\n    exit /b 1\n)\necho ✅ Git found\n\nREM Clone repository if not already cloned\necho.\necho [4/7] Setting up repository...\nif not exist \"barcode\" (\n    echo Cloning repository...\n    git clone https://github.com/shindeshailesh962/barcode.git\n    cd barcode\n) else (\n    echo Repository already exists, skipping clone.\n    cd barcode\n)\necho ✅ Repository ready\n\nREM Setup Backend\necho.\necho [5/7] Installing Backend dependencies...\ncd backend\nif not exist \".env\" (\n    echo Creating .env file from template...\n    copy .env.example .env\n    echo ⚠️  Please edit backend\\.env with your database credentials\n)\necho Installing npm packages...\ncall npm install\ncd ..\necho ✅ Backend setup complete\n\nREM Setup Frontend\necho.\necho [6/7] Installing Frontend dependencies...\ncd frontend\nif not exist \".env\" (\n    echo Creating .env file from template...\n    copy .env.example .env\n)\necho Installing npm packages...\ncall npm install\ncd ..\necho ✅ Frontend setup complete\n\nREM Setup Database\necho.\necho [7/7] Setting up Database...\necho Please enter your MySQL root password when prompted\npause\n\nmysql -u root -p < database/schema.sql\nif errorlevel 1 (\n    echo ❌ Database creation failed. Please check your MySQL password.\n    pause\n    exit /b 1\n)\necho ✅ Database created successfully\n\necho.\necho ===============================================================\necho ✅ Installation Complete!\necho ===============================================================\necho.\necho 📋 Next Steps:\necho.\necho 1. Edit configuration files:\necho    - Open backend\\.env in your text editor\necho    - Add your database credentials\necho.\necho 2. Start Backend (Open Command Prompt):\necho    cd backend\necho    npm start\necho    Server will run on: http://localhost:5000\necho.\necho 3. Start Frontend (Open another Command Prompt):\necho    cd frontend\necho    npm start\necho    Application will open at: http://localhost:3000\necho.\necho 🎉 Your application is ready to use!\necho.\necho 📚 Documentation:\necho    - Setup Guide: docs/SETUP.md\necho    - API Docs: docs/API.md\necho    - Architecture: docs/ARCHITECTURE.md\necho.\npause\n"
